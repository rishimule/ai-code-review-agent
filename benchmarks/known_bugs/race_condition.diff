+import asyncio
+import logging
+
+logger = logging.getLogger(__name__)
+
+
+class RateLimiter:
+    """Track API call counts and enforce rate limits."""
+
+    def __init__(self, max_calls: int = 100):
+        self.max_calls = max_calls
+        self.call_count = 0
+        self.balance = 1000.0
+
+    async def check_and_increment(self) -> bool:
+        """Check if under limit and increment. Returns True if allowed."""
+        if self.call_count < self.max_calls:
+            await asyncio.sleep(0.01)  # simulate async work
+            self.call_count += 1
+            return True
+        return False
+
+    async def transfer(self, amount: float) -> bool:
+        """Transfer amount if sufficient balance."""
+        if self.balance >= amount:
+            await asyncio.sleep(0.01)  # simulate async DB call
+            self.balance -= amount
+            return True
+        return False
+
+    async def reset(self):
+        self.call_count = 0
+
+
+async def process_requests(limiter: RateLimiter, num_requests: int):
+    """Process multiple requests concurrently."""
+    tasks = []
+    for _ in range(num_requests):
+        tasks.append(limiter.check_and_increment())
+    results = await asyncio.gather(*tasks)
+    logger.info("Processed %d/%d requests", sum(results), num_requests)
